# ────────────────────────────────────────────
# FROM บอกว่าเราเริ่มต้นจาก image อะไร
# เปรียบเหมือนการเลือกวัตถุดิบพื้นฐานก่อนปรุงอาหาร
# ────────────────────────────────────────────
FROM ubuntu:20.04

# ────────────────────────────────────────────
# ตั้งค่านี้เพื่อป้องกัน apt-get ถามคำถาม
# ระหว่าง build เช่น timezone selection
# เพราะตอน build ไม่มีใครนั่งตอบได้
# ────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive

# ────────────────────────────────────────────
# RUN คือการรันคำสั่ง shell ระหว่างสร้าง image
# เราเชื่อมหลายคำสั่งด้วย && และ \ เพื่อให้
# เป็น "layer" เดียว ประหยัดขนาด image
# ────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-tk \       
    && rm -rf /var/lib/apt/lists/*
# python3-tk จำเป็นสำหรับ matplotlib ที่จะแสดง GUI
# rm ท้ายสุดเพื่อลบ cache ของ apt ให้ image เล็กลง

# ────────────────────────────────────────────
# WORKDIR กำหนด folder ที่ทำงานภายใน container
# ถ้า folder ยังไม่มี Docker จะสร้างให้อัตโนมัติ
# ────────────────────────────────────────────
# WORKDIR /docker_ws

# ────────────────────────────────────────────
# COPY คัดลอกไฟล์จากเครื่องเราเข้าไปใน image
# เราแยก copy requirements.txt ออกมาก่อน
# เพราะ Docker มีระบบ cache — ถ้า requirements.txt
# ไม่เปลี่ยน Docker จะใช้ layer ที่ cache ไว้
# ทำให้ build ครั้งต่อไปเร็วขึ้นมาก
# ────────────────────────────────────────────
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# คัดลอก source code หลังจากติดตั้ง library แล้ว
# เพราะโค้ดเปลี่ยนบ่อยกว่า library มาก
# การเรียงลำดับแบบนี้ทำให้ Docker cache ทำงานได้ดี
# COPY plot.py .

# ────────────────────────────────────────────
# CMD คือคำสั่งที่รันเมื่อ container เริ่มทำงาน
# ต่างจาก RUN ตรงที่ RUN ทำงานตอน build image
# แต่ CMD ทำงานตอน run container
# ────────────────────────────────────────────
# CMD ["python3", "plot.py"]